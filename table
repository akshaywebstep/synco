STEP 5: Practical Sequelize example
Step A: super admin nikalo
const mainSuperAdmin = await getMainSuperAdminOfAdmin(req.admin.id);
const superAdminId = mainSuperAdmin.superAdmin.id;

Step B: us super admin ke saare admins lao
const admins = await Admin.findAll({
  where: {
    superAdminId,
  },
  attributes: ["id"],
});

const adminIds = admins.map(a => a.id);

Step C: booking listing query
const bookings = await Booking.findAll({
  where: {
    [Op.or]: [
      { parentAdminId: { [Op.in]: adminIds } },
      { parentAdminId: null }, // website bookings
    ],
  },
});

